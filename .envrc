# Carga automática de secrets de desarrollo
# Desencripta y exporta variables del archivo development.env.gpg

if [[ -f ~/.secrets/development.env.gpg ]]; then
    eval "$(gpg --quiet --decrypt ~/.secrets/development.env.gpg 2>/dev/null | grep -v '^#' | xargs -I {} echo export {})"
    echo "🔐 Secrets de development cargados"
fi
